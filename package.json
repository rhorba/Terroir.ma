{
  "name": "terroir-ma",
  "version": "0.1.0",
  "description": "Platform digitizing Morocco's terroir product certification chain under Law 25-06 (SDOQ)",
  "author": "Terroir.ma",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "nest build",
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,test}/**/*.ts\" --fix",
    "format": "prettier --write \"{src,test,shared}/**/*.{ts,json,yaml,md}\"",
    "format:check": "prettier --check \"{src,test,shared}/**/*.{ts,json,yaml,md}\"",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:unit": "jest --testPathPattern=test/unit",
    "test:integration": "jest --testPathPattern=test/integration",
    "test:e2e": "jest --testPathPattern=test/e2e",
    "test:cov": "jest --coverage",
    "test:unit:cov": "jest --testPathPattern=test/unit --coverage --coverageReporters=text --coverageReporters=lcov",
    "migration:run": "ts-node -r tsconfig-paths/register node_modules/.bin/typeorm migration:run -d src/database/data-source.ts",
    "migration:revert": "ts-node -r tsconfig-paths/register node_modules/.bin/typeorm migration:revert -d src/database/data-source.ts",
    "migration:generate": "ts-node -r tsconfig-paths/register node_modules/.bin/typeorm migration:generate -d src/database/data-source.ts",
    "migration:show": "ts-node -r tsconfig-paths/register node_modules/.bin/typeorm migration:show -d src/database/data-source.ts",
    "migration:check": "ts-node -r tsconfig-paths/register node_modules/.bin/typeorm migration:generate src/database/migrations/SchemaDriftCheck -d src/database/data-source.ts --check",
    "fonts:download": "node scripts/download-fonts.js",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1029.0",
    "@nestjs/cache-manager": "^2.3.0",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/microservices": "^10.3.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/swagger": "^7.3.0",
    "@nestjs/terminus": "^10.2.3",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^10.0.2",
    "cache-manager": "^5.4.0",
    "cache-manager-redis-yet": "^5.1.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "handlebars": "^4.7.8",
    "helmet": "^7.1.0",
    "jwks-rsa": "^3.1.0",
    "kafkajs": "^2.2.4",
    "nestjs-pino": "^4.1.0",
    "nodemailer": "^6.9.12",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.18.0",
    "pg": "^8.11.5",
    "pino": "^9.1.0",
    "pino-http": "^10.1.0",
    "qrcode": "^1.5.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@faker-js/faker": "^8.4.1",
    "@nestjs/cli": "^10.3.2",
    "@nestjs/schematics": "^10.1.1",
    "@nestjs/testing": "^10.3.0",
    "@testcontainers/postgresql": "^10.9.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.12.7",
    "@types/nodemailer": "^6.4.15",
    "@types/passport-jwt": "^4.0.1",
    "@types/pdfkit": "^0.17.5",
    "@types/qrcode": "^1.5.5",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.1.1",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.2",
    "passport-custom": "^1.1.1",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.2.5",
    "supertest": "^7.0.0",
    "testcontainers": "^10.9.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "lint-staged": {
    "*.{ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,yaml,yml,md}": [
      "prettier --write"
    ]
  }
}
