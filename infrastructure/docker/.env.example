# ─────────────────────────────────────────────────────────────────────────────
# Terroir.ma — Environment Variables Example (Docker context)
# Copy this file to .env.docker and fill in your values.
# NEVER commit .env.docker with real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# When running locally (outside Docker): use localhost
# When running inside Docker network: use container name (postgresql)
DATABASE_URL=postgresql://terroir:terroir_pass@localhost:5432/terroir_db
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=terroir
DATABASE_PASSWORD=terroir_pass
DATABASE_NAME=terroir_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Redpanda / Kafka ─────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:19092
KAFKA_CLIENT_ID=terroir-ma

# ── Keycloak ──────────────────────────────────────────────────────────────────
KEYCLOAK_URL=http://localhost:8443
KEYCLOAK_REALM=terroir-ma
KEYCLOAK_CLIENT_ID=api-client
KEYCLOAK_CLIENT_SECRET=REPLACE_WITH_YOUR_CLIENT_SECRET
KEYCLOAK_JWKS_URI=http://localhost:8443/realms/terroir-ma/protocol/openid-connect/certs

# ── SMTP ───────────────────────────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@terroir.ma

# ── QR Code & Verification ───────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
QR_HMAC_SECRET=REPLACE_WITH_RANDOM_256_BIT_SECRET_MINIMUM_32_CHARACTERS
QR_VERIFICATION_BASE_URL=http://localhost:3000/api/v1/verify

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_PRETTY=true

# ── CORS & Rate Limiting ──────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:4200,http://localhost:3000
RATE_LIMIT_TTL=900000
RATE_LIMIT_LIMIT=100
