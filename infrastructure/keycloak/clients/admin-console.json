{
  "clientId": "admin-console",
  "name": "Terroir.ma Admin Console",
  "description": "Internal platform administration console restricted to super-admin and certification-body roles. Confidential client using Authorization Code + PKCE flow.",
  "enabled": true,
  "publicClient": false,
  "standardFlowEnabled": true,
  "implicitFlowEnabled": false,
  "directAccessGrantsEnabled": false,
  "serviceAccountsEnabled": false,
  "secret": "change-me-in-production-admin",
  "attributes": {
    "pkce.code.challenge.method": "S256",
    "post.logout.redirect.uris": "http://localhost:4203/*"
  },
  "redirectUris": [
    "http://localhost:4203/*",
    "http://localhost:3000/admin/*"
  ],
  "webOrigins": [
    "http://localhost:4203",
    "http://localhost:3000"
  ],
  "protocol": "openid-connect",
  "fullScopeAllowed": false,
  "defaultClientScopes": ["openid", "profile", "email", "roles"],
  "optionalClientScopes": ["address", "phone"]
}
