{
  "id": "terroir-ma",
  "realm": "terroir-ma",
  "displayName": "Terroir.ma",
  "displayNameHtml": "<img src='/resources/terroir/login/img/terroir-logo.png' alt='Terroir.ma' width='120'/><div>Terroir.ma</div>",
  "enabled": true,
  "loginWithEmailAllowed": true,
  "registrationAllowed": false,
  "registrationEmailAsUsername": true,
  "rememberMe": true,
  "verifyEmail": true,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 300,
  "minimumQuickLoginWaitSeconds": 60,
  "waitIncrementSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,
  "maxDeltaTimeSeconds": 43200,
  "failureFactor": 5,
  "sslRequired": "external",
  "accessTokenLifespan": 300,
  "accessTokenLifespanForImplicitFlow": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "offlineSessionIdleTimeout": 2592000,
  "offlineSessionMaxLifespanEnabled": false,
  "accessCodeLifespan": 60,
  "accessCodeLifespanUserAction": 300,
  "accessCodeLifespanLogin": 1800,
  "passwordPolicy": "length(8) and upperCase(1) and digits(1) and specialChars(1)",
  "internationalizationEnabled": true,
  "supportedLocales": ["ar", "fr", "zgh"],
  "defaultLocale": "ar",
  "loginTheme": "terroir",
  "accountTheme": "terroir",
  "adminTheme": "keycloak",
  "emailTheme": "terroir",
  "smtpServer": {
    "host": "mailpit",
    "port": "1025",
    "from": "noreply@terroir.ma",
    "fromDisplayName": "Terroir.ma",
    "ssl": "false",
    "starttls": "false",
    "auth": "false"
  },
  "roles": {
    "realm": [
      {
        "name": "super-admin",
        "description": "Full platform access. Can manage all cooperatives, override certifications, access all modules, and perform administrative operations.",
        "composite": false,
        "clientRole": false,
        "attributes": {
          "permissions": ["*"],
          "level": ["10"]
        }
      },
      {
        "name": "cooperative-admin",
        "description": "Administrator for a specific cooperative. Can manage members, submit certification requests, view all reports for their cooperative.",
        "composite": false,
        "clientRole": false,
        "attributes": {
          "permissions": ["cooperative:manage", "product:write", "certification:submit"],
          "level": ["7"]
        }
      },
      {
        "name": "cooperative-member",
        "description": "Member of a cooperative. Can log harvests, view their cooperative's certifications, and manage their farm parcels.",
        "composite": false,
        "clientRole": false,
        "attributes": {
          "permissions": ["cooperative:read", "product:write:own", "farm:manage:own"],
          "level": ["3"]
        }
      },
      {
        "name": "lab-technician",
        "description": "Laboratory technician. Can receive test submissions, enter results, and issue lab reports for product batches.",
        "composite": false,
        "clientRole": false,
        "attributes": {
          "permissions": ["lab:read", "lab:write", "product:read"],
          "level": ["5"]
        }
      },
      {
        "name": "inspector",
        "description": "Field inspector assigned by certification body. Can view assigned inspections, submit field reports, and upload inspection evidence.",
        "composite": false,
        "clientRole": false,
        "attributes": {
          "permissions": ["inspection:read:assigned", "inspection:write:assigned", "cooperative:read"],
          "level": ["5"]
        }
      },
      {
        "name": "certification-body",
        "description": "Certification authority officer. Can manage the full certification lifecycle: assign inspectors, review reports, grant or deny certifications.",
        "composite": false,
        "clientRole": false,
        "attributes": {
          "permissions": ["certification:manage", "inspection:manage", "cooperative:read", "product:read"],
          "level": ["8"]
        }
      },
      {
        "name": "customs-agent",
        "description": "Customs and border control agent. Can scan and verify QR codes, view export documents, and validate certification status for cross-border shipments.",
        "composite": false,
        "clientRole": false,
        "attributes": {
          "permissions": ["certification:verify", "export:read", "qr:verify"],
          "level": ["4"]
        }
      },
      {
        "name": "consumer",
        "description": "End consumer or market buyer. Can scan QR codes to view product origin, certification status, and cooperative information.",
        "composite": false,
        "clientRole": false,
        "attributes": {
          "permissions": ["qr:verify", "product:read:public", "cooperative:read:public"],
          "level": ["1"]
        }
      },
      {
        "name": "service-account",
        "description": "Machine-to-machine service account for internal microservices and automation jobs. Not for human users.",
        "composite": false,
        "clientRole": false,
        "attributes": {
          "permissions": ["internal:*"],
          "level": ["6"]
        }
      }
    ]
  },
