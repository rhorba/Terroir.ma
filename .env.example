# App
NODE_ENV=development
PORT=3000

# Database (PostgreSQL with PostGIS)
DATABASE_URL=postgresql://terroir:terroir_pass@localhost:5432/terroir_db
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=terroir
DATABASE_PASSWORD=terroir_pass
DATABASE_NAME=terroir_db

# Redis (for QR verification cache and certification status)
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# Kafka / Redpanda
KAFKA_BROKERS=localhost:19092
KAFKA_CLIENT_ID=terroir-ma

# Keycloak (OpenID Connect)
KEYCLOAK_URL=http://localhost:8443
KEYCLOAK_REALM=terroir-ma
KEYCLOAK_CLIENT_ID=api-client
KEYCLOAK_CLIENT_SECRET=change-me
KEYCLOAK_JWKS_URI=http://localhost:8443/realms/terroir-ma/protocol/openid-connect/certs

# Email (Mailpit dev SMTP sink)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@terroir.ma

# QR Code Verification
# SECURITY: Change QR_HMAC_SECRET to a random 256-bit (32 byte) key before any real use
QR_HMAC_SECRET=change-this-to-a-random-256-bit-secret-key-minimum-32-characters
QR_VERIFICATION_BASE_URL=http://localhost:3000/api/v1/verify

# Logging
LOG_LEVEL=debug
LOG_PRETTY=true

# CORS
CORS_ORIGINS=http://localhost:4200,http://localhost:3000

# Rate Limiting
RATE_LIMIT_TTL=900000
RATE_LIMIT_LIMIT=100

# MinIO (S3-compatible object storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=terroir-uploads
MINIO_USE_SSL=false

# Redpanda Admin API
REDPANDA_ADMIN_URL=http://localhost:9644

# Redpanda Schema Registry (Avro — P2-S3)
SCHEMA_REGISTRY_URL=http://localhost:8081

# Frontend (terroir-portal / terroir-public Docker services)
NEXTAUTH_SECRET=changeme-portal-secret-32chars
KEYCLOAK_PORTAL_SECRET=changeme

# Monitoring (Prometheus + Grafana — monitoring/full Docker profile)
GRAFANA_PASSWORD=terroir

# Distributed Tracing (Jaeger — monitoring/full Docker profile)
# OTEL_SDK_DISABLED=true suppresses gRPC errors when Jaeger is not running
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=terroir-api
OTEL_SDK_DISABLED=true
